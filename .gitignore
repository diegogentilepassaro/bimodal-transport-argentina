# ==============================================================================
# .gitignore — Argentina transport replication package (new_repo/)
# ==============================================================================

# ---- Raw data files (large; only readmes and .gitkeep are committed) -------
# Data files in any format — replicators obtain these per readme.md instructions
data/raw/**/*.dta
data/raw/**/*.csv
data/raw/**/*.xlsx
data/raw/**/*.xls
data/raw/**/*.parquet
data/raw/**/*.sav
data/raw/**/*.dat
data/raw/**/*.dat.gz
data/raw/**/*.zip
data/raw/**/*.shp
data/raw/**/*.shx
data/raw/**/*.dbf
data/raw/**/*.prj
data/raw/**/*.cpg
data/raw/**/*.sbn
data/raw/**/*.sbx
data/raw/**/*.qpj
data/raw/**/*.gpkg
data/raw/**/*.geojson
data/raw/**/*.xml
data/raw/**/*.pdf
data/raw/**/*.txt
# Keep readmes and .gitkeep
!data/raw/**/readme.md
!data/raw/**/.gitkeep

# ---- Generated data (everything under data/derived/) ----------------------
data/derived/**
!data/derived/.gitkeep
# Keep data file manifests (documentation of what the code produces)
# Must un-ignore parent dirs for the exception to work
!data/derived/base/
!data/derived/base/*/
!data/derived/02_hypothetical_networks/
!data/derived/**/data_file_manifest*.log

# ---- Generated results (re-created by running main.R) ---------------------
# Tables: commit CSV (GitHub-readable) so coauthors can see numbers in-repo.
# Keep .tex gitignored since they're consumed by paper.tex at compile time.
results/tables/*.tex
# Figures: commit PNG (GitHub-previewable) so coauthors can see visuals.
# Keep .pdf gitignored since they're consumed by paper.tex at compile time.
results/figures/*.pdf
results/scalars.tex

# ---- Log files (directory kept via .gitkeep) -------------------------------
logs/*.Rout
*.Rout
# Keep run logs (evidence of successful execution)
!logs/clean_*.log

# ---- R session artefacts ---------------------------------------------------
.Rhistory
.RData
.Rproj.user/

# ---- renv cache (not the lockfile) -----------------------------------------
renv/library/
renv/staging/
renv/.cache/

# ---- Python bytecode -------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ---- Python virtual environments -------------------------------------------
.venv/
venv/
env/

# ---- macOS / editor noise --------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---- LaTeX build artefacts -------------------------------------------------
paper/*.aux
paper/*.log
paper/*.out
paper/*.blg
paper/*.bbl
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
# Commit the built PDFs (paper.pdf + paper_planned.pdf) so coauthors
# and reviewers can read the latest draft without running LaTeX.
# Everything *.pdf else lives outside paper/ and is covered by specific rules.

# ---- Raw data files (large; only readmes and .gitkeep committed) -----------
data/raw/**/*.xlsx
data/raw/**/*.dta
data/raw/**/*.csv
data/raw/**/*.sav

# ---- Large spatial files ---------------------------------------------------
*.tif
*.geotiff
*.img

# ---- .gitkeep files ARE committed ------------------------------------------
!**/.gitkeep
